{
  "compilerOptions": {
    "target": "es2019",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": ["node_modules/@types"],
    "types": ["node", "jest"],
    "lib": ["es2019"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/__tests__/*"]
}
